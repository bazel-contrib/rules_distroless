"Examples module for rules_distroless"

module(
    name = "rules_distroless_examples",
    version = "0.0.0",
)

bazel_dep(name = "rules_distroless", version = "0.0.0")
local_path_override(
    module_name = "rules_distroless",
    path = "..",
)

bazel_dep(name = "aspect_bazel_lib", version = "2.14.0")
bazel_dep(name = "bazel_lib", version = "3.0.0-rc.0")
